<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AssemblyName>simpe.splash</AssemblyName>
    <RootNamespace>SimPe.Windows.Forms</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="GDF">
      <HintPath>$(ReleaseDir)GDF.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <ProjectReference Include="../NetDocks/NetDocks.csproj" />
    <Reference Include="simpe.helper">
      <HintPath>$(ReleaseDir)simpe.helper.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="HelpForm.cs" />
    <Compile Include="HelpForm.Designer.cs" />
    <Compile Include="Properties/AssemblyInfo.cs" />
    <Compile Include="Properties/Resources.Designer.cs" />
    <Compile Include="SplashForm.cs" />
    <Compile Include="SplashForm.Designer.cs" />
    <Compile Include="SplashScreen.cs" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="img/bottom.png" />
    <EmbeddedResource Include="img/center.png" />
    <EmbeddedResource Include="img/top.png" />
    <EmbeddedResource Include="SplashForm.resx">
      <DependentUpon>SplashForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Include="img/splash.png" />
    <EmbeddedResource Include="Properties/Resources.resx" />
    <EmbeddedResource Include="HelpForm.resx">
      <DependentUpon>HelpForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Include="img/splashao.png" />
    <EmbeddedResource Include="img/topao.png" />
  </ItemGroup>
</Project>
