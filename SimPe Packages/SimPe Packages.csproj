<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AssemblyName>simpe.package</AssemblyName>
    <RootNamespace>SimPe.Packages</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="simpe.clst">
      <HintPath>$(ReleaseDir)simpe.clst.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="simpe.helper">
      <HintPath>$(ReleaseDir)simpe.helper.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="simpe.interfaces">
      <HintPath>$(ReleaseDir)simpe.interfaces.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="AssemblyInfo.cs" />
    <Compile Include="ExtractableFile.cs" />
    <Compile Include="File.cs" />
    <Compile Include="FileTableBase.cs" />
    <Compile Include="FileTableItem.cs" />
    <Compile Include="FileTableItemType.cs" />
    <Compile Include="GeneratableFile.cs" />
    <Compile Include="HeaderData.cs" />
    <Compile Include="HeaderHole.cs" />
    <Compile Include="HeaderIndex.cs" />
    <Compile Include="HoleIndexItem.cs" />
    <Compile Include="PackageFiles.cs" />
    <Compile Include="PackageMaintainer.cs" />
    <Compile Include="PackageRepair.cs" />
    <Compile Include="PackedFile.cs" />
    <Compile Include="PackedFileDescription.cs" />
    <Compile Include="PackedFileDescriptors.cs" />
    <Compile Include="Settings.cs" />
    <Compile Include="StreamMaintainer.cs" />
    <Compile Include="XmlPackageReaderBase.cs" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="PackageFiles.resx">
      <DependentUpon>PackageFiles.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>
</Project>
