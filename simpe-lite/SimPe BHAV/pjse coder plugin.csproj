    <PostBuildEvent>set base=$(TargetName)-$(ConfigurationName)
set src=Source-$(ConfigurationName)
set mydate=%25date%25
set dd=%25mydate:~0,2%25
set mm=%25mydate:~3,2%25
set yy=%25mydate:~6,4%25
set mytime=%25time%25
set h=%25mytime:~0,2%25
set m=%25mytime:~3,2%25
set s=%25mytime:~6,2%25
set suffix=%25yy%25%25mm%25%25dd%25-%25h%25%25m%25
set tarv=

cd "$(ProjectDir)"

if exist Plugins rmdir /s/q Plugins
mkdir Plugins
mkdir "Plugins\$(TargetName)"

(cd "$(TargetDir)"
tar c --exclude "*.bat" . ) | tar x%25tarv%25 -C "Plugins"

(cd ..
tar c LICENSE.txt *.package) | tar x%25tarv%25 -C "Plugins\$(TargetName)"
tar c --exclude=CVS CHANGES.txt PJSE_Help | tar x%25tarv%25 -C "Plugins\$(TargetName)"

tar c Plugins | (cd ..\..\SimPe
tar xv)

del ..\"%25base%25*"
7za a -tzip -r -mx9 "..\%25base%25-%25suffix%25.zip" Plugins

if not $(ConfigurationName)==Release goto skip

tar cv Plugins | bzip2 &gt; "..\%25base%25-%25suffix%25.tar.bz2"
7za a -t7z -mx9 -ms "..\%25base%25-%25suffix%25.7z" Plugins

cd "$(ProjectDir).."
if exist "%25src%25" rmdir /s/q "%25src%25"
del "%25src%25*"
mkdir "%25src%25"

tar c --exclude="%25src%25" --exclude=CVS --exclude=*.7z --exclude=*.zip --exclude=*.tar.bz2 --exclude=.project --exclude=.metadata --exclude=bin --exclude=obj --exclude=Plugins --exclude=*.suo --exclude=*.csproj.user --exclude=*.bak --exclude=.#* . | tar x%25tarv%25 -C "%25src%25"
7za a -tzip -r -mx9 "%25src%25-%25suffix%25.zip" "%25src%25"
if exist "%25src%25" rmdir /s/q "%25src%25"

:skip:
</PostBuildEvent>
  </PropertyGroup>
